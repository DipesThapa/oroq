<?xml version="1.0" encoding="utf-8"?>
<!-- The OroQ Q mark (deck §1): white ring with the blue needle tail breaking
     out toward bottom-right. Kept inside the 66dp adaptive-icon safe zone. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Ring -->
    <path
        android:pathData="M54,35.5 a16.5,16.5 0 1,0 0.02,0 z"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="6"
        android:fillColor="#00000000" />

    <!-- Needle tail at 45°, breaking out of the ring -->
    <path
        android:pathData="M65.7,63.7 L77.5,75.5"
        android:strokeWidth="6.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startColor="#FF60A5FA"
                android:centerColor="#FF2563EB"
                android:endColor="#FF1E3A8A"
                android:startX="65.7"
                android:startY="63.7"
                android:endX="77.5"
                android:endY="75.5"
                android:type="linear" />
        </aapt:attr>
    </path>
</vector>

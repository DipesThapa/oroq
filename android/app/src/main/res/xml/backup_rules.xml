<?xml version="1.0" encoding="utf-8"?>
<!--
   Auto Backup rules for API 25-30 (android:fullBackupContent).
   Everything is backed up by default; we subtract the one DataStore that
   holds secrets so it never leaves the device via Google cloud backup.
-->
<full-backup-content>
    <!-- family_config holds this device's private keyset, the parent session
         token, and pairing keys. Must never be uploaded to cloud backup. -->
    <exclude domain="file" path="datastore/family_config.preferences_pb" />
</full-backup-content>

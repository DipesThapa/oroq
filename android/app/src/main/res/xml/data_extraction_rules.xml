<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup / transfer rules for API 31+ (android:dataExtractionRules).
   We exclude the secret DataStore from cloud backup so the device private
   keyset, parent session token, and pairing keys never reach Google servers.
   Local device-to-device transfer keeps them, so a parent migrating phones
   doesn't have to re-pair every child.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/family_config.preferences_pb" />
    </cloud-backup>
</data-extraction-rules>

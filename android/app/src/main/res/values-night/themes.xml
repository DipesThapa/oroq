        <item name="colorPrimary">@color/sb_primary</item>
        <item name="colorPrimaryVariant">@color/sb_primary_dark</item>
        <item name="colorOnPrimary">@color/sb_on_primary</item>
        <item name="colorSecondary">@color/sb_primary</item>
        <item name="colorSecondaryVariant">@color/sb_primary_dark</item>
        <item name="colorOnSecondary">@color/sb_on_primary</item>
        <item name="android:statusBarColor">@color/oroq_bg_dark</item>
        <item name="android:windowBackground">@color/oroq_bg_dark</item>
    </style>
</resources>
